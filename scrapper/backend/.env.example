# Contractor Scraper Agent — backend environment
# Copy to `.env` (local) or set these on Cloud Run. Only the essentials are listed;
# everything else auto-detects or has a sane default (see README).

# ── Google Sheets (datastore) ──
GOOGLE_SHEETS_ID=                       # spreadsheet ID (from its URL)
GOOGLE_CLIENT_EMAIL=                    # service-account email (e.g. sheets-bot@<project>.iam.gserviceaccount.com)
GOOGLE_PRIVATE_KEY=                     # SA private key, one line with literal \n: "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Scraping / enrichment ──
APIFY_API_TOKEN=                        # Google Maps discovery + DBPR fallback + BBB
APOLLO_API_KEY=                         # email/owner/company enrichment (paid key reveals emails)

# ── Auth ──
JWT_SECRET=                             # long random string for signing login tokens

# ── Frontend / CORS (REQUIRED in production) ──
FRONTEND_URL=                           # your deployed frontend origin, e.g. https://<app>.vercel.app
                                        # (without this the deployed UI gets blocked by CORS)
