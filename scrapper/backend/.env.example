# ──────────────────────────────────────────────────────────────
# Contractor Scraper Agent — Backend Environment Variables
# Copy this file to .env and fill in real values (NEVER commit .env)
# ──────────────────────────────────────────────────────────────

# Database (Neon PostgreSQL — get from neon.tech dashboard)
# Format: postgresql://user:pass@host.neon.tech/dbname?sslmode=require
POSTGRES_DSN=postgresql://user:pass@host.neon.tech/contractor_scraper?sslmode=require

# Third-party API keys
OUTSCRAPER_API_KEY=
HUNTER_API_KEY=
APOLLO_API_KEY=
PDL_API_KEY=

# Optional fallback scraper
APIFY_API_TOKEN=

# CORS — allow Vercel frontend to call this API
# Local dev: http://localhost:5173
# Production: https://contractor-scraper.vercel.app
FRONTEND_URL=http://localhost:5173

# Data storage
# Local dev: ./data
# Render production: /var/data
DATA_DIR=./data
EXPORT_DIR=./exports

# ──────────────────────────────────────────────────────────────
# Auth (JWT)
# ──────────────────────────────────────────────────────────────
# Use a long random string in production (e.g. `openssl rand -hex 32`).
# A test user `test@example.com` / `123456` is auto-seeded on first boot.
JWT_SECRET=dev-insecure-change-me
JWT_EXPIRE_HOURS=24
